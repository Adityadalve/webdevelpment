When using the Scala bridge, you use com.databricks.sdk.scala.dbutils.DBUtils

import org.apache.spark.sql.Dataset;
import org.apache.spark.sql.Row;
import org.apache.spark.sql.SparkSession;
// This is the Scala-bridge import used in Java
import com.databricks.sdk.scala.dbutils.DBUtils;

public class JavaWithScalaBridge {

    public static void main(String[] args) {

        SparkSession spark = SparkSession.builder().getOrCreate();

        // Access secrets via the Scala-bridge utility
        // This is concise and works perfectly in Java
        String scope = "my-akv-scope";

        String username = DBUtils.getDBUtils().secrets().get(scope, "db-user");
        String password = DBUtils.getDBUtils().secrets().get(scope, "db-pass");

        // Use the secrets in Spark JDBC
        Dataset<Row> df = spark.read()
                .format("jdbc")
                .option("url", "jdbc:postgresql://hostname:5432/db")
                .option("user", username)
                .option("password", password)
                .option("dbtable", "sales_data")
                .load();

        df.show();
    }
}


